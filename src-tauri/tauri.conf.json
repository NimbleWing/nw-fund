{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "灵翼基金管理系统",
  "version": "../package.json",
  "identifier": "com.nimblewing.nw-fund",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "灵翼基金管理系统",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "center": true
      },
      {
        "label": "preference",
        "title": "偏好设置",
        "url": "/preference",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU0MzJBMURFNjg0NDM1QzMKUldURE5VUm8zcUV5NUF2YW5rOG05OC9iK056TFRXVmw4cGtaV21seGEzalRQQ2RiOU90VnVIZWUK",
      "endpoints": ["https://github.com/NimbleWing/nw-fund/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
