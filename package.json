{
  "name": "nw-fund",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "clean:bundle": "rimraf src-tauri/target/release/bundle/nsis",
    "tauri:build": "pnpm clean:bundle && pnpm tauri build && pnpm rename-bundle && pnpm generate:json",
    "rename-bundle": "node scripts/rename-bundle.cjs",
    "generate:json": "cargo run --manifest-path src-tauri/Cargo.toml --bin generate-latest-json",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "lint:all": "pnpm lint && pnpm lint:rust",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "format:all": "pnpm format && pnpm format:rust",
    "prepare": "husky"
  },
  "dependencies": {
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "ahooks": "^3.9.7",
    "dayjs": "^1.11.20",
    "i18next": "^26.0.6",
    "lucide-react": "^1.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "^17.0.4",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.1",
    "rimraf": "^6.1.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "2.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.0",
    "vite": "^8.0.8"
  },
  "lint-staged": {
    "*.rs": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "*.{ts,tsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ]
  }
}
