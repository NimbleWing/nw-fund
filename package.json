{
  "name": "nw-fund",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "lint:all": "pnpm lint && pnpm lint:rust",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "format:all": "pnpm format && pnpm format:rust",
    "prepare": "husky"
  },
  "dependencies": {
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "@tauri-apps/api": "2.10.1",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "2.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.0",
    "vite": "^8.0.8"
  },
  "lint-staged": {
    "*.rs": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "*.{ts,tsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ]
  }
}
